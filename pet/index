============================================================ */
let _ac;
function _initAC(){
  if(!_ac){
    try{_ac=new (window.AudioContext||window.webkitAudioContext)();}catch(e){}
  }
}
function _tone(f,d,t,v,delay){
  _initAC();if(!_ac)return;
  try{
    const o=_ac.createOscillator(),g=_ac.createGain();
    o.connect(g);g.connect(_ac.destination);
    o.type=t||'sine';
    o.frequency.setValueAtTime(f,_ac.currentTime+(delay||0));
    g.gain.setValueAtTime(v||0.12,_ac.currentTime+(delay||0));
    g.gain.exponentialRampToValueAtTime(0.001,_ac.currentTime+(delay||0)+d);
    o.start(_ac.currentTime+(delay||0));
    o.stop(_ac.currentTime+(delay||0)+d);
  }catch(e){}
}
function sfxFlip(){_tone(660,.05,'sine',.07);}
function sfxKnown(){_tone(523,.1,'sine',.12);_tone(784,.15,'sine',.12,.1);}
function sfxSkip(){_tone(440,.08,'sine',.08);}
function sfxDone(){[523,659,784,1047].forEach((f,i)=>_tone(f,.15,'sine',.14,i*.1));}
document.addEventListener('touchstart',_initAC,{once:true});
document.addEventListener('click',_initAC,{once:true});

/* ============================================================
   语音系统（沿用 PSLE 版本的高质量 voice 选择逻辑）
============================================================ */
let _voices=[];
function _loadVoices(){
  _voices=window.speechSynthesis?window.speechSynthesis.getVoices():[];
}
if(window.speechSynthesis){
  _loadVoices();
  window.speechSynthesis.onvoiceschanged=_loadVoices;
}

function _pickVoice(preferAccent){
  const pref=(preferAccent||'en-GB').toLowerCase();
  function scoreVoice(v){
    let s=0;
    const name=v.name.toLowerCase();
    const lang=v.lang.toLowerCase();
    // 语言：优先匹配用户选择的口音
    if(lang===pref) s+=60;
    else if(lang==='en-gb') s+=(pref==='en-gb'?60:25);
    else if(lang==='en-us') s+=(pref==='en-us'?60:22);
    else if(lang==='en-au') s+=15;
    else if(lang.startsWith('en')) s+=8;
    else return -1;
    // 高质量标识
    if(name.includes('neural')) s+=50;
    if(name.includes('online')) s+=40;
    if(name.includes('premium')) s+=40;
    if(name.includes('enhanced')) s+=35;
    if(name.includes('natural')) s+=35;
    // 英式优质发音人
    if(name.includes('sonia')) s+=45;     // Microsoft Sonia
    if(name.includes('libby')) s+=42;     // Microsoft Libby
    if(name.includes('ryan')) s+=38;      // Microsoft Ryan
    if(name.includes('daniel')) s+=32;    // Apple Daniel
    if(name.includes('serena')) s+=30;    // Apple Serena
    if(name.includes('kate')) s+=28;
    // 美式优质发音人
    if(name.includes('aria')) s+=40;
    if(name.includes('jenny')) s+=40;
    if(name.includes('ava')) s+=40;
    if(name.includes('emma')) s+=38;
    if(name.includes('samantha')) s+=30;
    // Google 中性偏好
    if(name.includes('google uk')) s+=35;
    if(name.includes('google us')) s+=30;
    if(name.includes('google')) s+=22;
    // 扣分项
    if(name.includes('compact')) s-=30;
    if(name.includes('espeak')) s-=50;
    if(name==='microsoft david') s-=20;
    if(name==='microsoft mark') s-=20;
    return s;
  }
  const ranked=_voices.map(v=>({voice:v,score:scoreVoice(v)}))
    .filter(x=>x.score>0).sort((a,b)=>b.score-a.score);
  return ranked.length?ranked[0].voice:null;
}

let _utter=null;
function speak(text,btnEl){
  if(!window.speechSynthesis) return;
  const clean=(text||'').replace(/[\u4e00-\u9fa5，。！？、；：""''（）【】·]/g,' ').replace(/\s+/g,' ').trim();
  if(!clean) return;
  window.speechSynthesis.cancel();
  document.querySelectorAll('.speak-btn.playing').forEach(b=>b.classList.remove('playing'));
  if(_voices.length===0) _loadVoices();
  _utter=new SpeechSynthesisUtterance(clean);
  const voice=_pickVoice(settings.accent);
  if(voice){
    _utter.voice=voice;
    _utter.lang=voice.lang;
  } else {
    _utter.lang=settings.accent;
  }
  _utter.rate=settings.speed;
  _utter.pitch=1.05;
  _utter.volume=1.0;
  if(btnEl){
    btnEl.classList.add('playing');
    _utter.onend=()=>btnEl.classList.remove('playing');
    _utter.onerror=()=>btnEl.classList.remove('playing');
  }
  setTimeout(()=>window.speechSynthesis.speak(_utter),50);
}

/* ============================================================
   长按释义（沿用 PSLE 版本）
============================================================ */
const _WD={};
V.forEach(w=>{_WD[w[1].toLowerCase()]={zh:w[2]};});

let _lpT=null,_lpEl=null;
function _rmTip(){if(_lpEl){_lpEl.remove();_lpEl=null;}}
function _showTip(word,x,y){
  _rmTip();
  const clean=word.toLowerCase().replace(/[^a-z]/g,'');
  const info=_WD[clean];
  if(!info) return;
  const tip=document.createElement('div');
  tip.className='lp-tip';
  tip.innerHTML=`<div class="lp-tip-w">${word}</div><div class="lp-tip-zh">${info.zh}</div>`;
  const tipX=Math.min(x,window.innerWidth-240);
  const tipY=Math.max(y-90,10);
  tip.style.left=tipX+'px';
  tip.style.top=tipY+'px';
  document.body.appendChild(tip);
  _lpEl=tip;
  setTimeout(_rmTip,3000);
}
document.addEventListener('touchstart',e=>{
  const tgt=e.target;
  if(!tgt.closest('.feg')) return;
  const text=(tgt.textContent||'').trim();
  if(!text||text.includes(' ')||text.length>30) return;
  _lpT=setTimeout(()=>{
    const t=e.touches[0];
    _showTip(text,t.clientX,t.clientY);
    navigator.vibrate&&navigator.vibrate(30);
  },600);
},{passive:true});
document.addEventListener('touchend',()=>clearTimeout(_lpT),{passive:true});
document.addEventListener('touchmove',()=>{clearTimeout(_lpT);_rmTip();},{passive:true});
document.addEventListener('click',_rmTip);

/* ============================================================
   状态管理
============================================================ */
const LS_KEY='pet_flashcard_v1';
const LS_SET='pet_flashcard_settings_v1';

let settings={accent:'en-GB',speed:0.85,auto:1};
function loadSettings(){
  try{
    const s=localStorage.getItem(LS_SET);
    if(s){settings={...settings,...JSON.parse(s)};}
  }catch(e){}
  // 同步 UI
  document.querySelectorAll('#accentSeg .seg-btn').forEach(b=>{
    b.classList.toggle('active',b.dataset.accent===settings.accent);
  });
  document.querySelectorAll('#speedSeg .seg-btn').forEach(b=>{
    b.classList.toggle('active',parseFloat(b.dataset.speed)===settings.speed);
  });
  document.querySelectorAll('#autoSeg .seg-btn').forEach(b=>{
    b.classList.toggle('active',parseInt(b.dataset.auto)===settings.auto);
  });
}
function saveSettings(){
  try{localStorage.setItem(LS_SET,JSON.stringify(settings));}catch(e){}
}
function setAccent(a){settings.accent=a;saveSettings();loadSettings();toast('已切换至 '+(a==='en-GB'?'英式发音':'美式发音'));}
function setSpeed(s){settings.speed=s;saveSettings();loadSettings();}
function setAuto(v){settings.auto=v;saveSettings();loadSettings();}

let progress={mastered:new Set(),today:new Set(),lastDate:'',streak:0};
function loadProgress(){
  try{
    const s=localStorage.getItem(LS_KEY);
    if(s){
      const p=JSON.parse(s);
      progress.mastered=new Set(p.mastered||[]);
      progress.today=new Set(p.today||[]);
      progress.lastDate=p.lastDate||'';
      progress.streak=p.streak||0;
    }
  }catch(e){}
  const today=new Date().toISOString().slice(0,10);
  if(progress.lastDate!==today){
    // 新的一天，重置 today，更新 streak
    if(progress.today.size>0){
      const prev=progress.lastDate;
      const y=new Date();y.setDate(y.getDate()-1);
      const yesterday=y.toISOString().slice(0,10);
      if(prev===yesterday){progress.streak+=1;} else {progress.streak=1;}
    }
    progress.today=new Set();
    progress.lastDate=today;
    saveProgress();
  }
}
function saveProgress(){
  try{
    localStorage.setItem(LS_KEY,JSON.stringify({
      mastered:Array.from(progress.mastered),
      today:Array.from(progress.today),
      lastDate:progress.lastDate,
      streak:progress.streak
    }));
  }catch(e){}
}
function resetProgress(){
  if(!confirm('确定重置所有学习进度吗？')) return;
  progress={mastered:new Set(),today:new Set(),lastDate:new Date().toISOString().slice(0,10),streak:0};
  saveProgress();
  toggleSettings();
  initF(fst.filter);
  rFlash();
  toast('进度已重置');
}

/* ============================================================
   单词卡核心逻辑
============================================================ */
const DAILY_TARGET=20;

let fst={filter:'all',order:[],done:new Set(),flipped:false};

function initF(cat){
  fst.filter=cat||'all';
  let pool=[];
  V.forEach((w,i)=>{
    if(fst.filter==='all'||w[0]===fst.filter) pool.push(i);
  });
  // 优先未掌握的
  pool.sort((a,b)=>{
    const am=progress.mastered.has(a)?1:0;
    const bm=progress.mastered.has(b)?1:0;
    if(am!==bm) return am-bm;
    return Math.random()-0.5;
  });
  fst.order=pool;
  fst.done=new Set();
  fst.flipped=false;
}

function rFlash(){
  const app=document.getElementById('cardZone');
  const chipRow=document.getElementById('chipRow');

  // 渲染分类 chips
  const counts={all:V.length};
  V.forEach(w=>{counts[w[0]]=(counts[w[0]]||0)+1;});
  const cats=Object.keys(CM).map(k=>[k,CM_ZH[k]]);
  chipRow.innerHTML=
    `<span class="chip ${fst.filter==='all'?'chip-on':''}" onclick="sfxFlip();initF('all');rFlash()">全部 ${counts.all}</span>`+
    cats.map(([k,v])=>`<span class="chip ${fst.filter===k?'chip-on':''}" onclick="sfxFlip();initF('${k}');rFlash()">${v} ${counts[k]||0}</span>`).join('');

  // 进度条
  const total=fst.order.length;
  const doneCount=fst.done.size;
  const pct=total?Math.round(doneCount/total*100):0;
  document.getElementById('progressBar').style.width=pct+'%';

  // 剩余单词
  const remaining=fst.order.filter(i=>!fst.done.has(i));
  if(remaining.length===0){
    app.innerHTML=`
      <div class="done-card">
        <div class="done-crest">✦</div>
        <div class="done-title">This Round Complete</div>
        <div class="done-sub">本组 ${total} 词已学习完成</div>
        <div class="action-row">
          <button class="btn btn-wine" onclick="sfxFlip();initF(fst.filter);rFlash()">再学一轮</button>
          <button class="btn btn-ink" onclick="sfxFlip();initF('all');rFlash()">换一类</button>
        </div>
      </div>`;
    updateRings();
    sfxDone();
    return;
  }

  const ci=remaining[0];
  const w=V[ci];
  const cat=CM[w[0]]||'Word';

  app.innerHTML=`
    <div class="flip-scene" onclick="flipCard()">
      <div class="flip-card ${fst.flipped?'flipped':''}" id="flipCard">
        <div class="flip-front">
          <div class="fcat">${cat}</div>
          <div class="fw">${w[1]}</div>
          <div class="speak-row">
            <button class="speak-btn" onclick="event.stopPropagation();speak('${w[1].replace(/'/g,"\\'")}',this)" title="朗读单词">🔊</button>
          </div>
          <div class="tap-hint">Tap to reveal</div>
        </div>
        <div class="flip-back">
          <div class="fcat">${cat}</div>
          <div class="fw">${w[1]}</div>
          <div class="fcn">${w[2]}</div>
          ${w[3]?`
            <div class="feg-wrap">
              <div class="feg" onclick="event.stopPropagation();speak('${(w[3]||'').replace(/'/g,"\\'")}',this.querySelector('.speak-btn-wide')||this)">
                ${w[3].split(' ').map(word=>`<span>${word}</span>`).join(' ')}
              </div>
              ${w[4]?`<div class="feg-zh">${w[4]}</div>`:''}
            </div>`:''}
        </div>
      </div>
    </div>
    <div class="action-row">
      <button class="btn btn-ghost" onclick="skipWord()">跳过 Skip</button>
      <button class="btn btn-ink" onclick="markKnown()">认识 ✓</button>
    </div>
  `;

  updateRings();

  // 自动朗读（切到新词时）
  if(settings.auto){
    setTimeout(()=>{
      const btn=document.querySelector('.flip-front .speak-btn');
      if(btn) speak(w[1],btn);
    },300);
  }
}

function flipCard(){
  const card=document.getElementById('flipCard');
  if(!card) return;
  fst.flipped=!fst.flipped;
  card.classList.toggle('flipped',fst.flipped);
  sfxFlip();
  // 翻到背面时朗读例句
  if(fst.flipped && settings.auto){
    const remaining=fst.order.filter(i=>!fst.done.has(i));
    if(remaining.length){
      const w=V[remaining[0]];
      if(w[3]){
        setTimeout(()=>{
          const btn=document.querySelector('.flip-back .feg');
          if(btn) speak(w[3],btn);
        },700);
      }
    }
  }
}

function markKnown(){
  const remaining=fst.order.filter(i=>!fst.done.has(i));
  if(remaining.length===0) return;
  const ci=remaining[0];
  fst.done.add(ci);
  progress.mastered.add(ci);
  progress.today.add(ci);
  saveProgress();
  fst.flipped=false;
  sfxKnown();
  pandaBounce();
  setTimeout(rFlash,180);
}

function skipWord(){
  const remaining=fst.order.filter(i=>!fst.done.has(i));
  if(remaining.length===0) return;
  const ci=remaining[0];
  fst.done.add(ci);
  progress.today.add(ci);
  saveProgress();
  fst.flipped=false;
  sfxSkip();
  setTimeout(rFlash,120);
}

function pandaBounce(){
  const p=document.getElementById('hero-panda');
  if(!p) return;
  p.classList.remove('bounce');
  void p.offsetWidth;
  p.classList.add('bounce');
}

/* ============================================================
   进度环
============================================================ */
function updateRings(){
  // Today: 今日学习 / 每日目标
  const todayCount=progress.today.size;
  const todayPct=Math.min(todayCount/DAILY_TARGET,1);
  setRing('ring0',todayPct);
  document.getElementById('ringNum0').textContent=`${todayCount}/${DAILY_TARGET}`;
  // Mastered: 已掌握 / 总词库
  const masteredPct=V.length?progress.mastered.size/V.length:0;
  setRing('ring1',masteredPct);
  document.getElementById('ringNum1').textContent=progress.mastered.size;
  // Streak
  const streakPct=Math.min(progress.streak/30,1);
  setRing('ring2',streakPct);
  document.getElementById('ringNum2').textContent=progress.streak;
}
function setRing(id,pct){
  const el=document.getElementById(id);
  if(!el) return;
  const circ=2*Math.PI*28;
  el.setAttribute('stroke-dasharray',circ);
  el.setAttribute('stroke-dashoffset',circ*(1-pct));
}

/* ============================================================
   设置弹窗
============================================================ */
function toggleSettings(){
  const m=document.getElementById('settingsModal');
  m.classList.toggle('open');
}

/* ============================================================
   Toast
============================================================ */
function toast(msg){
  const old=document.querySelector('.toast');
  if(old) old.remove();
  const t=document.createElement('div');
  t.className='toast';t.textContent=msg;
  document.body.appendChild(t);
  setTimeout(()=>t.remove(),2000);
}

/* ============================================================
   启动
============================================================ */
loadSettings();
loadProgress();
initF('all');
rFlash();

</script>
